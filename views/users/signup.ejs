<%layout('layouts/boilerplate.ejs') %>
<body>
    <br>
    <br>
    <h3 class="offset-2">SignUp on WanderInn</h3>
    <br>
    <form method="POST" action="/signup" class="needs-validation" novalidate>
        <div class="row">
            <div class="col-8 offset-2">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input name="username" placeholder="username" type="text" id="username" class="form-control" required>
                    <div class="invalid-feedback">Username is required</div>

                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email ID</label>
                    <input name="email" placeholder="Email ID" type="text" id="email" class="form-control" required>
                    <div class="invalid-feedback">Email ID is required</div>

                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" placeholder="password" type="password" id="password" class="form-control" required>
                    <div class="invalid-feedback">Password is required</div>

                </div>

                <button class="btn btn-dark add-btn">SignUp</button>
                <br>
                <br>
            </div>
        </div>

    </form>
</body>
